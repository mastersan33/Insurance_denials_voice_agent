FROM python:3.12-slim AS builder

WORKDIR /app
COPY backend/requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# ---------------------------------------------------------------------------
FROM python:3.12-slim

# Non-root user for least-privilege execution
RUN groupadd -r appuser && useradd -r -g appuser appuser

WORKDIR /app

COPY --from=builder /install /usr/local
COPY backend/ ./backend/
COPY agent/   ./agent/

ENV PYTHONPATH=/app

# Source code is read-only; create a writable data directory for SQLite
# (in production, use PostgreSQL and a persistent volume instead)
RUN mkdir -p /data && \
    chmod -R 555 /app && \
    chown -R appuser:appuser /data

USER appuser

# SQLite database lives outside the read-only source tree
ENV DATABASE_URL=sqlite+aiosqlite:////data/app.db

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/v1/health')"

# Use gunicorn + uvicorn workers in production for graceful restarts
CMD ["uvicorn", "backend.app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4", "--no-access-log"]
