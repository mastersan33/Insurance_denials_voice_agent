# ============================================================
# Outbound Billing Voice Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
#
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=local          # local | dev | staging | production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production    # REQUIRED in production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────
# Local dev (SQLite — no setup required):
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://agent:password@postgres:5432/billing_agent

POSTGRES_DB=billing_agent
POSTGRES_USER=agent
POSTGRES_PASSWORD=change-me-in-production    # REQUIRED

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:changeme_in_production@redis:6379/0
REDIS_PASSWORD=changeme_in_production    # REQUIRED
REDIS_MAX_CONNECTIONS=50

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...     # REQUIRED for AI features
OPENAI_MODEL=gpt-4o
LLM_MODEL=gpt-4o-mini
ENABLE_REAL_LLM=true

# ── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # REQUIRED
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx      # REQUIRED
TWILIO_PHONE_NUMBER=+15005550006
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# ── ElevenLabs ───────────────────────────────────────────────
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx     # REQUIRED
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_STT_MODEL=scribe_v1

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Frontend URL (used in password-reset emails) ─────────────
FRONTEND_URL=http://localhost:5173

# ── SMTP (optional — password reset emails) ──────────────────
# If not configured, reset links are logged to console in dev mode
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@your-domain.com


# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
